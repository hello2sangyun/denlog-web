{
  "name": "denlog-web",
  "version": "0.1.9",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --webpack",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "lint": "eslint",
    "build:app": "npm run build && electron-builder --mac --win"
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-serve": "^3.0.1",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "zustand": "^5.0.13"
  },
  "main": "main.js",
  "build": {
    "appId": "com.denlog.app",
    "productName": "Denlog Desktop",
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": ["universal"]
        },
        {
          "target": "zip",
          "arch": ["universal"]
        }
      ],
      "icon": "build/icon.png",
      "hardenedRuntime": true
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "hello2sangyun",
        "repo": "denlog"
      }
    ]
  }
}
